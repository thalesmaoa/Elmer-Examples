# Configurações Locais do Ambiente (stack.env)
# -------------------------------------------------------------
# Configuração de execução do ParaView (pvbatch)
# -------------------------------------------------------------

# Opção 1: ParaView instalado via Flatpak (Debian/Linux)
PVBATCH_CMD=flatpak run --command=pvbatch org.paraview.ParaView

# Opção 2: Instalação padrão nativa (pvbatch configurado no PATH do sistema)
# PVBATCH_CMD=pvbatch
